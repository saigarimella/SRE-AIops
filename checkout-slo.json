{
  "uid": "checkout-slo",
  "title": "Checkout SLO Demo",
  "tags": [
    "sre",
    "demo",
    "streamflix"
  ],
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "🌐 All Services — at a glance",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "API Gateway",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                },
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"api-gateway\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Catalog",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                },
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"catalog\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Streaming",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                },
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"streaming\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Payments",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                },
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"payments\"}"
        }
      ]
    },
    {
      "type": "row",
      "title": "🎯 Consolidated SLO/SLI — End-to-End Checkout Journey (all 4 services chained)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Consolidated Availability SLI (Journey)",
      "description": "Probability the ENTIRE checkout journey (Gateway → Catalog → Streaming → Payments) is reachable end-to-end. Multiplies each hop's availability, since one broken link breaks the journey.",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.98
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(up{job=\"api-gateway\"}[5m]) * on() group_left() avg_over_time(up{job=\"catalog\"}[5m]) * on() group_left() avg_over_time(up{job=\"streaming\"}[5m]) * on() group_left() avg_over_time(up{job=\"payments\"}[5m])"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Consolidated Success Rate SLI (Journey)",
      "description": "Probability a request that reaches the journey succeeds at every hop. Multiplies each service's success rate.",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.97
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(http_requests_total{job=\"api-gateway\",status!~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"api-gateway\"}[5m]))) * on() group_left() (sum(rate(http_requests_total{job=\"catalog\",status!~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"catalog\"}[5m]))) * on() group_left() (sum(rate(http_requests_total{job=\"streaming\",status!~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"streaming\"}[5m]))) * on() group_left() (sum(rate(http_requests_total{job=\"payments\",status!~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"payments\"}[5m])))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Journey Error Budget Remaining (SLO 98%)",
      "description": "Error budget for the whole checkout journey, using a 98% target (looser than any single service, since the chain compounds).",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": -100,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 25
              },
              {
                "color": "green",
                "value": 60
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - ((1 - (avg_over_time(up{job=\"api-gateway\"}[30m]) * on() group_left() avg_over_time(up{job=\"catalog\"}[30m]) * on() group_left() avg_over_time(up{job=\"streaming\"}[30m]) * on() group_left() avg_over_time(up{job=\"payments\"}[30m]))) / (1 - 0.98)))"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Weakest Link — per-service availability",
      "description": "Same 4 numbers as the SLO 1 row, ranked so you can spot the bottleneck dragging the journey number down.",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.98
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(up{job=\"api-gateway\"}[5m])",
          "legendFormat": "API Gateway"
        },
        {
          "refId": "B",
          "expr": "avg_over_time(up{job=\"catalog\"}[5m])",
          "legendFormat": "Catalog"
        },
        {
          "refId": "C",
          "expr": "avg_over_time(up{job=\"streaming\"}[5m])",
          "legendFormat": "Streaming"
        },
        {
          "refId": "D",
          "expr": "avg_over_time(up{job=\"payments\"}[5m])",
          "legendFormat": "Payments"
        }
      ]
    },
    {
      "type": "row",
      "title": "📊 The Four Golden Signals — all 4 services (Traffic, Errors, Latency, Saturation)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Traffic — req/s per service",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "fillOpacity": 12,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{job=\"api-gateway\"}[1m]))",
          "legendFormat": "API Gateway"
        },
        {
          "refId": "B",
          "expr": "sum(rate(http_requests_total{job=\"catalog\"}[1m]))",
          "legendFormat": "Catalog"
        },
        {
          "refId": "C",
          "expr": "sum(rate(http_requests_total{job=\"streaming\"}[1m]))",
          "legendFormat": "Streaming"
        },
        {
          "refId": "D",
          "expr": "sum(rate(http_requests_total{job=\"payments\"}[1m]))",
          "legendFormat": "Payments"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Errors — % 5xx per service",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 6,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "fillOpacity": 12,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(http_requests_total{job=\"api-gateway\",status=~\"5..\"}[1m])) or vector(0)) / sum(rate(http_requests_total{job=\"api-gateway\"}[1m]))",
          "legendFormat": "API Gateway"
        },
        {
          "refId": "B",
          "expr": "100 * (sum(rate(http_requests_total{job=\"catalog\",status=~\"5..\"}[1m])) or vector(0)) / sum(rate(http_requests_total{job=\"catalog\"}[1m]))",
          "legendFormat": "Catalog"
        },
        {
          "refId": "C",
          "expr": "100 * (sum(rate(http_requests_total{job=\"streaming\",status=~\"5..\"}[1m])) or vector(0)) / sum(rate(http_requests_total{job=\"streaming\"}[1m]))",
          "legendFormat": "Streaming"
        },
        {
          "refId": "D",
          "expr": "100 * (sum(rate(http_requests_total{job=\"payments\",status=~\"5..\"}[1m])) or vector(0)) / sum(rate(http_requests_total{job=\"payments\"}[1m]))",
          "legendFormat": "Payments"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency — p95 (ms) per service",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
            "fillOpacity": 12,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"api-gateway\"}[1m])))",
          "legendFormat": "API Gateway"
        },
        {
          "refId": "B",
          "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"catalog\"}[1m])))",
          "legendFormat": "Catalog"
        },
        {
          "refId": "C",
          "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"streaming\"}[1m])))",
          "legendFormat": "Streaming"
        },
        {
          "refId": "D",
          "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"payments\"}[1m])))",
          "legendFormat": "Payments"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Saturation — goroutines per service",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 18,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "fillOpacity": 12,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "go_goroutines{job=\"api-gateway\"}",
          "legendFormat": "API Gateway"
        },
        {
          "refId": "B",
          "expr": "go_goroutines{job=\"catalog\"}",
          "legendFormat": "Catalog"
        },
        {
          "refId": "C",
          "expr": "go_goroutines{job=\"streaming\"}",
          "legendFormat": "Streaming"
        },
        {
          "refId": "D",
          "expr": "go_goroutines{job=\"payments\"}",
          "legendFormat": "Payments"
        }
      ]
    },
