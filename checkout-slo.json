        {
          "refId": "D",
          "expr": "avg_over_time(up{job=\"payments\"}[5m])",
          "legendFormat": "Payments"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Availability Error Budget Remaining",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": -100,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 25
              },
              {
