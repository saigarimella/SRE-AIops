          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - ((1 - avg_over_time(up{job=\"api-gateway\"}[30m])) / (1 - 0.995)))",
          "legendFormat": "API Gateway"
        },
        {
          "refId": "B",
          "expr": "100 * (1 - ((1 - avg_over_time(up{job=\"catalog\"}[30m])) / (1 - 0.995)))",
