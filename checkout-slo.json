          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(up{job=\"api-gateway\"}[5m])",
          "legendFormat": "API Gateway"
        },
        {
          "refId": "B",
          "expr": "avg_over_time(up{job=\"catalog\"}[5m])",
          "legendFormat": "Catalog"
        },
        {
